# =============================================================================
# RAG Platform — Environment Variables
# Copy this file to .env and fill in all values before running docker compose.
# Never commit .env to version control.
# =============================================================================

# Anthropic
ANTHROPIC_API_KEY=

# Voyage AI
VOYAGE_API_KEY=

# PostgreSQL
POSTGRES_USER=rag
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rag_platform
DATABASE_URL=postgresql+asyncpg://rag:changeme@postgres:5432/rag_platform

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=documents

# LangFuse (self-hosted)
LANGFUSE_SECRET_KEY=changeme-secret
LANGFUSE_PUBLIC_KEY=changeme-public
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_SALT=changeme-salt

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
