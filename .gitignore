# =============================================================================
# SECRETS — never commit these
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
.uv/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Type checking
.mypy_cache/
.ruff_cache/

# =============================================================================
# Node / Next.js
# =============================================================================
node_modules/
.next/
out/
.npm

# =============================================================================
# Docker
# =============================================================================
# Don't ignore docker-compose files — those should be committed
# But ignore any local override you create yourself
docker-compose.override.yml

# =============================================================================
# Data & storage
# =============================================================================
# Local MinIO data (generated at runtime)
minio-data/
postgres-data/
redis-data/

# Generated eval datasets — can be regenerated; don't commit large JSON files
evals/datasets/*.json

# =============================================================================
# Editors & OS
# =============================================================================
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
